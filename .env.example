# ===========================
# Application
# ===========================
APP_NAME=DealOS AI
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ===========================
# Backend
# ===========================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1
CORS_ORIGINS=["http://localhost:5173"]

# ===========================
# Database (PostgreSQL)
# ===========================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=dealos
POSTGRES_PASSWORD=dealos_dev_password
POSTGRES_DB=dealos
DATABASE_URL=postgresql+asyncpg://dealos:dealos_dev_password@postgres:5432/dealos

# ===========================
# Redis
# ===========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# ===========================
# MinIO (S3-Compatible Storage)
# ===========================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=dealos_minio
MINIO_SECRET_KEY=dealos_minio_secret
MINIO_BUCKET=dealos-documents
MINIO_USE_SSL=false

# ===========================
# JWT Authentication
# ===========================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================
# OpenAI
# ===========================
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536

# ===========================
# Rate Limiting
# ===========================
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_PER_MINUTE=10

# ===========================
# File Upload
# ===========================
MAX_FILE_SIZE_MB=50
ALLOWED_EXTENSIONS=pdf,docx,xlsx,csv,pptx,txt
